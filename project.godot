[application]

config/name="Scary Mansion"
run/main_scene="res://World/World.tscn"
config/icon="res://icon.png"

[autoload]

GlobalItems="*res://GlobalItems.gd"
Global="*res://Global.gd"
GlobalAssets="*res://GlobalAssets.gd"
MapGeneration="*res://World/MapGeneration.gd"

[display]

window/size/width=784
window/size/height=448
window/stretch/mode="2d"
window/stretch/aspect="keep"

